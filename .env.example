# ── SQL Database ─────────────────────────────────────────────────────────────
# SQL_DIALECT options: mysql | mariadb | mssql | postgres | sqlite
SQL_DIALECT=
SQL_HOST=
SQL_PORT=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
# Set SQL_SSL=true if your remote DB requires SSL (most cloud providers do)
SQL_SSL=false

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASSWORD=

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → EXTERNAL_AUTH_URL_DEV | "production" → EXTERNAL_AUTH_URL_PROD
NODE_ENV=production

# ── External Auth API (Symfony) ───────────────────────────────────────────────
EXTERNAL_AUTH_URL_DEV=http://localhost:8000
EXTERNAL_AUTH_URL_PROD=

# ── External Auth Public Key (RS256) ─────────────────────────────────────────
# Paste the PEM public key content here, replacing newlines with \n
# Example: EXTERNAL_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBI...\n-----END PUBLIC KEY-----"
# If not set, the server will fall back to reading backend/keys/public.pem (legacy)
EXTERNAL_JWT_PUBLIC_KEY=